<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🎭 JESTER HUB - Sistema de Keys VIP</title>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.5.1/dist/confetti.browser.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        body {
            background: linear-gradient(135deg, #0f0c1f 0%, #1a1428 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        
        .link-copiavel {
            background: rgba(180, 70, 200, 0.2);
            border: 2px solid #b446c8;
            border-radius: 50px;
            padding: 15px 25px;
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            backdrop-filter: blur(10px);
        }
        
        .link-copiavel span {
            color: white;
            font-size: 18px;
            font-family: monospace;
            word-break: break-all;
        }
        
        .link-copiavel button {
            background: #b446c8;
            border: none;
            color: white;
            padding: 10px 20px;
            border-radius: 30px;
            cursor: pointer;
            font-weight: bold;
            transition: 0.3s;
            white-space: nowrap;
            margin-left: 15px;
        }
        
        .link-copiavel button:hover {
            background: #d482f0;
            transform: scale(1.05);
        }
        
        .container {
            max-width: 1200px;
            width: 100%;
        }
        
        .header {
            text-align: center;
            margin-bottom: 40px;
        }
        
        .logo {
            font-size: 80px;
            margin-bottom: 10px;
            filter: drop-shadow(0 0 20px #b446c8);
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }
        
        .header h1 {
            color: #b446c8;
            font-size: 48px;
            text-shadow: 0 0 20px rgba(180, 70, 200, 0.5);
            letter-spacing: 2px;
        }
        
        .header p {
            color: #d482f0;
            font-size: 18px;
            margin-top: 10px;
        }
        
        .badge {
            background: linear-gradient(45deg, #b446c8, #d482f0);
            color: white;
            padding: 5px 15px;
            border-radius: 20px;
            display: inline-block;
            margin-top: 10px;
            font-weight: bold;
        }
        
        .cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
            margin-bottom: 40px;
        }
        
        .card {
            background: rgba(30, 25, 40, 0.9);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 30px;
            text-align: center;
            border: 2px solid #b446c8;
            transition: 0.3s;
            position: relative;
            overflow: hidden;
        }
        
        .card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(180, 70, 200, 0.3);
        }
        
        .card-icon {
            font-size: 50px;
            margin-bottom: 20px;
        }
        
        .card h3 {
            color: #d482f0;
            font-size: 24px;
            margin-bottom: 10px;
        }
        
        .card .price {
            font-size: 36px;
            color: white;
            font-weight: bold;
            margin: 20px 0;
        }
        
        .card .price span {
            font-size: 16px;
            color: #888;
        }
        
        .card .features {
            list-style: none;
            margin: 20px 0;
            text-align: left;
        }
        
        .card .features li {
            color: #ccc;
            margin: 10px 0;
            font-size: 14px;
        }
        
        .card .features li:before {
            content: "✓ ";
            color: #b446c8;
            font-weight: bold;
        }
        
        .card-btn {
            background: linear-gradient(45deg, #b446c8, #d482f0);
            border: none;
            color: white;
            padding: 15px 30px;
            border-radius: 30px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
            width: 100%;
        }
        
        .painel-dono {
            background: rgba(30, 25, 40, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 30px;
            border: 2px solid #b446c8;
            margin-bottom: 30px;
        }
        
        .painel-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            flex-wrap: wrap;
            gap: 20px;
        }
        
        .painel-header h2 {
            color: #d482f0;
            font-size: 28px;
        }
        
        .senha-input {
            background: rgba(40, 35, 50, 0.9);
            border: 2px solid #b446c8;
            border-radius: 30px;
            padding: 12px 20px;
            color: white;
            width: 250px;
            font-size: 16px;
            outline: none;
        }
        
        .gerador-area {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .tipo-selector {
            background: rgba(40, 35, 50, 0.9);
            border: 2px solid #b446c8;
            border-radius: 15px;
            padding: 15px;
            cursor: pointer;
            transition: 0.3s;
            text-align: center;
        }
        
        .tipo-selector.selecionado {
            background: #b446c8;
            box-shadow: 0 0 20px #b446c8;
        }
        
        .tipo-nome { color: white; font-weight: bold; }
        .tipo-desc { color: #aaa; font-size: 12px; }

        .quantidade-input {
            width: 100%;
            padding: 15px;
            background: rgba(40, 35, 50, 0.9);
            border: 2px solid #b446c8;
            border-radius: 15px;
            color: white;
            margin-bottom: 20px;
        }
        
        .gerar-btn {
            width: 100%;
            padding: 18px;
            background: linear-gradient(45deg, #b446c8, #d482f0);
            border: none;
            border-radius: 15px;
            color: white;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

        .resultado {
            background: rgba(40, 35, 50, 0.9);
            border-radius: 15px;
            padding: 20px;
            border: 1px solid #b446c8;
            margin-top: 20px;
        }

        .key-item {
            background: rgba(30, 25, 40, 0.9);
            padding: 15px;
            margin: 8px 0;
            border-radius: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-left: 4px solid #b446c8;
        }

        .key-codigo { color: white; font-family: monospace; font-weight: bold; }
        .key-tipo-badge { padding: 2px 8px; border-radius: 4px; font-size: 10px; text-transform: uppercase; margin-right: 10px;}
        .trial-badge { background: #3498db; }
        .vip-badge { background: #9b59b6; }
        .lifetime-badge { background: #f1c40f; color: black; }

        .acoes-rodape { display: flex; gap: 10px; margin-top: 15px; }
        .acoes-rodape button { flex: 1; padding: 10px; background: #2d1a44; border: 1px solid #b446c8; color: white; border-radius: 5px; cursor: pointer; }

        .footer { text-align: center; color: #666; font-size: 12px; margin-top: 30px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="link-copiavel">
            <span id="linkSite">https://joker2011.github.io/jester-keys</span>
            <button onclick="copiarLink()">📋 COPIAR LINK</button>
        </div>
        
        <div class="header">
            <div class="logo">🎭</div>
            <h1>JESTER HUB</h1>
            <p>Sistema Oficial de Keys VIP</p>
            <div class="badge">by Joker & Família</div>
        </div>
        
        <div class="cards">
            <div class="card">
                <div class="card-icon">🔑</div>
                <h3>Key Trial</h3>
                <div class="price">10 <span>dias</span></div>
                <ul class="features">
                    <li>Acesso por 10 dias</li>
                    <li>Todas as funções básicas</li>
                    <li>Fly speed normal</li>
                </ul>
                <button class="card-btn" onclick="selecionarTipo('trial')">🎯 GERAR TRIAL</button>
            </div>
            
            <div class="card">
                <div class="card-icon">💎</div>
                <h3>Key VIP</h3>
                <div class="price">30 <span>dias</span></div>
                <ul class="features">
                    <li>Acesso por 30 dias</li>
                    <li>Fly 2x mais rápido</li>
                    <li>Comandos de Admin VIP</li>
                </ul>
                <button class="card-btn" onclick="selecionarTipo('vip')">💎 GERAR VIP</button>
            </div>
            
            <div class="card">
                <div class="card-icon">👑</div>
                <h3>Key Lifetime</h3>
                <div class="price">∞ <span>para sempre</span></div>
                <ul class="features">
                    <li>Acesso PERMANENTE</li>
                    <li>Prioridade em updates</li>
                    <li>Nome nos créditos</li>
                </ul>
                <button class="card-btn" onclick="selecionarTipo('lifetime')">👑 GERAR LIFETIME</button>
            </div>
        </div>
        
        <div class="painel-dono">
            <div class="painel-header">
                <h2>⚡ PAINEL DO DONO</h2>
                <div>
                    <input type="password" id="senhaDono" class="senha-input" placeholder="Senha do Dono" value="Joker2011">
                </div>
            </div>
            
            <div class="gerador-area" id="selecaoTipo">
                <div class="tipo-selector" id="sel-trial" onclick="selecionarTipoPainel('trial')">
                    <div class="tipo-nome">TRIAL</div>
                    <div class="tipo-desc">10 dias</div>
                </div>
                <div class="tipo-selector selecionado" id="sel-vip" onclick="selecionarTipoPainel('vip')">
                    <div class="tipo-nome">VIP</div>
                    <div class="tipo-desc">30 dias</div>
                </div>
                <div class="tipo-selector" id="sel-lifetime" onclick="selecionarTipoPainel('lifetime')">
                    <div class="tipo-nome">LIFETIME</div>
                    <div class="tipo-desc">Permanente</div>
                </div>
            </div>
            
            <input type="number" id="quantidade" min="1" max="50" value="5" class="quantidade-input">
            <button class="gerar-btn" onclick="gerarKeys()">⚡ GERAR KEYS AGORA</button>
            
            <div class="resultado" id="resultado" style="display: none;">
                <h3>📋 KEYS GERADAS:</h3>
                <div id="keysList"></div>
                <div class="acoes-rodape">
                    <button onclick="copiarTodas()">📋 COPIAR TODAS</button>
                    <button onclick="exportarTXT()">📄 EXPORTAR TXT</button>
                </div>
            </div>
        </div>
        
        <div class="footer">
            <p>© 2025 Joker & Família - Todos os direitos reservados</p>
        </div>
    </div>

    <script>
        const SENHA_DONO = "Joker2011";
        let tipoSelecionado = "vip";
        let keysGeradas = [];
        
        function copiarLink() {
            navigator.clipboard.writeText(document.getElementById('linkSite').innerText);
            alert('Link copiado!');
        }
        
        function selecionarTipoPainel(tipo) {
            tipoSelecionado = tipo;
            document.querySelectorAll('.tipo-selector').forEach(el => el.classList.remove('selecionado'));
            document.getElementById('sel-' + tipo).classList.add('selecionado');
        }

        function selecionarTipo(tipo) {
            selecionarTipoPainel(tipo);
            document.querySelector('.painel-dono').scrollIntoView({ behavior: 'smooth' });
        }

        function gerarKeyUnica(tipo) {
            const prefixo = { trial: "JESTER-10D-", vip: "JESTER-30D-", lifetime: "JESTER-LT-" }[tipo];
            return prefixo + Math.random().toString(36).substring(2, 10).toUpperCase();
        }

        function gerarKeys() {
            if (document.getElementById('senhaDono').value !== SENHA_DONO) {
                alert('Senha Incorreta!');
                return;
            }
            
            const qtd = document.getElementById('quantidade').value;
            keysGeradas = [];
            const list = document.getElementById('keysList');
            list.innerHTML = '';
            
            for(let i=0; i<qtd; i++) {
                const k = gerarKeyUnica(tipoSelecionado);
                keysGeradas.push(k);
                list.innerHTML += `
                    <div class="key-item">
                        <span class="key-codigo">${k}</span>
                        <span class="key-tipo-badge ${tipoSelecionado}-badge">${tipoSelecionado}</span>
                        <button onclick="navigator.clipboard.writeText('${k}'); alert('Copiado!')">Copiado</button>
                    </div>`;
            }
            document.getElementById('resultado').style.display = 'block';
            confetti({ particleCount: 150, spread: 70, origin: { y: 0.6 }, colors: ['#b446c8', '#ffffff'] });
        }

        function copiarTodas() {
            navigator.clipboard.writeText(keysGeradas.join('\n'));
            alert('Todas as keys foram copiadas!');
        }

        function exportarTXT() {
            const element = document.createElement('a');
            const file = new Blob([keysGeradas.join('\n')], {type: 'text/plain'});
            element.href = URL.createObjectURL(file);
            element.download = "keys_jester.txt";
            document.body.appendChild(element);
            element.click();
        }
    </script>
</body>
  </html>
  
